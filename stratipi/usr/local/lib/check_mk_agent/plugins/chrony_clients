#!/usr/bin/env python3

import subprocess


_WINDOWS = (
    ("1m",           60),
    ("5m",          300),
    ("15m",         900),
    ("1h",        3_600),
    ("day",      86_400),
    ("week",    604_800),
    ("month", 2_592_000),
)




################################################################################
# Convert length string to raw seconds. ex: "1h" to 3600
################################################################################
def seconds(sec: str) -> int:
    try:
        match sec[-1]:
            case "y": return int(sec[:-1]) * 31_536_000
            case "d": return int(sec[:-1]) *     86_400
            case "h": return int(sec[:-1]) *      3_600
            case "m": return int(sec[:-1]) *         60
            case "s": return int(sec[:-1])
            case _:   return int(sec)
    except Exception as e:
        pass
    return 0




################################################################################
# Stream "chronyc clients" output line-by-line and bucket each client directly.
# Counts flow straight from the pipe into the buckets.
################################################################################
def chronyc_clients() -> dict[str, int] | None:
    try:
        proc = subprocess.Popen(
            ["chronyc", "-n", "clients"],
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1,  # line-buffered
        )
    except Exception:
        return None

    counts = {label: 0 for label, _ in _WINDOWS}
    total = 0

    try:
        for line in iter(proc.stdout.readline, ""):
            line = line.strip()
            if (not line) or ("===" in line) or ("Hostname" in line):
                continue

            parts = line.split()
            if len(parts) < 6:
                continue

            age = seconds(parts[5])
            total += 1
            for label, secs in _WINDOWS:
                if age <= secs:
                    counts[label] += 1
    except Exception:
        proc.terminate()
        return None

    proc.wait()

    if proc.returncode != 0:
        return None

    counts["_total"] = total
    return counts




################################################################################
# Do all the things!
################################################################################
def main():
    counts = chronyc_clients()

    # Ya b0rkt it! :(
    if counts is None:
        print("2 \"Chrony requests\" Error querying chronyc")
        print("2 \"Chrony requests long-term\" Error querying chronyc")
        print("2 \"Chrony requests total\" Error querying chronyc")
        return

    # Convert totals to requests/sec
    rates = {label: counts[label] / secs for label, secs in _WINDOWS}

    total = counts["_total"]
    print(f'0 "Chrony requests" 1m={rates["1m"]:.4f}|5m={rates["5m"]:.2f}|15m={rates["15m"]:.2f}|1h={rates["1h"]:.2f} 1m: {rates["1m"]:.2f}, 5m: {rates["5m"]:.2f}, 15m: {rates["15m"]:.2f}, 1h: {rates["1h"]:.2f}')
    print(f'0 "Chrony requests long-term" day={rates["day"]:.2f}|week={rates["week"]:.2f}|month={rates["month"]:.2f} Day: {rates["day"]:.2f}, Week: {rates["week"]:.2f}, Month: {rates["month"]:.2f}')
    print(f'0 "Chrony requests total" total={total} Total clients: {total}')




################################################################################
# Primary entry point
################################################################################
if __name__ == "__main__":
    main()
