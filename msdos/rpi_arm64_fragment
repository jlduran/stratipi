# EFI VARIABLES FROM SD CARD
CONFIG_ENV_FAT_DEVICE_AND_PART=""
CONFIG_ENV_IS_IN_FAT=y
CONFIG_EFI_VARIABLE_FILE_STORE=y
CONFIG_FAT_WRITE=y

# BOOT STUFF
CONFIG_RPI_EFI_NR_SPIN_PAGES=2

# AUTOBOOT LOGIC
CONFIG_AUTOBOOT_KEYED=y
CONFIG_AUTOBOOT_PROMPT="Autobooting in %d seconds, press \"<Esc>\" to stop\n"
CONFIG_AUTOBOOT_STOP_STR="\x1b"
CONFIG_AUTOBOOT_DELAY_STR=""
CONFIG_AUTOBOOT_STOP_STR_ENABLE=y

# ONLY USE HDMI/USB FOR CONSOLE, NOT SERIAL
CONFIG_CONSOLE_MUX=y
CONFIG_SYS_CONSOLE_IS_IN_ENV=y
CONFIG_SYS_DEVICE_NULLDEV=y
CONFIG_STD_DEVICES_SETTINGS="stdin=usbkbd,nulldev;stdout=vidconsole,nulldev;stderr=vidconsole,nulldev"

# DISABLE TRYING TO SEND DEBUG DATA TO SERIAL
CONFIG_DEBUG_UART=n
CONFIG_DEBUG_UART_PL011=n

# DISABLE SERIAL DRIVERS IN U-BOOT
# SERIAL IS GPS, NOT CONSOLE!
CONFIG_SERIAL_PRESENT=y
CONFIG_DM_SERIAL=n
CONFIG_PL011_SERIAL=n
CONFIG_BCM283X_PL011_SERIAL=n

